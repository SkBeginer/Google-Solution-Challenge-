{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role"]
    },
    "Claim": {
      "title": "Insurance Claim",
      "description": "Vehicle damage claim details and AI analysis.",
      "type": "object",
      "properties": {
        "claimId": { "type": "string" },
        "userId": { "type": "string" },
        "vehicleType": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "review", "approved", "rejected"] },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "voiceNote": { "type": "string" },
        "images": { "type": "array" },
        "analysis": { "type": "object" },
        "fraudRisk": { "type": "string", "enum": ["low", "medium", "high"] },
        "estimatedCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/claims/{claimId}": {
      "schema": "Claim",
      "description": "Claims submitted by users."
    }
  }
}
